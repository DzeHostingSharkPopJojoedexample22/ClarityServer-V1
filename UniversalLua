-- Функция обновления
function updateRainbowCrosshair()
    if not rainbowCrosshairEnabled then
        topLine.Visible=false
        bottomLine.Visible=false
        leftLine.Visible=false
        rightLine.Visible=false
        return
    end
    
    -- Медленная смена цветов
    crosshairHue=(crosshairHue+0.002)%1
    local color=Color3.fromHSV(crosshairHue,1,1)
    
    -- Медленное вращение по часовой стрелке
    crosshairAngle=(crosshairAngle+0.5)%360
    local rad=math.rad(crosshairAngle)
    
    -- Динамический gap (пульсация)
    crosshairGap=crosshairGap+crosshairGapDir*0.1
    if crosshairGap>8 then
        crosshairGap=8
        crosshairGapDir=-1
    elseif crosshairGap<2 then
        crosshairGap=2
        crosshairGapDir=1
    end
    
    local viewportSize=Camera.ViewportSize
    local centerX=viewportSize.X/2
    local centerY=viewportSize.Y/2
    
    -- Направления с учетом gap
    local dir1=Vector2.new(math.cos(rad), math.sin(rad))
    local dir2=Vector2.new(-math.sin(rad), math.cos(rad))
    local dir3=-dir1
    local dir4=-dir2
    
    -- Точки старта с gap
    local start1=Vector2.new(centerX+dir1.X*crosshairGap, centerY+dir1.Y*crosshairGap)
    local start2=Vector2.new(centerX+dir2.X*crosshairGap, centerY+dir2.Y*crosshairGap)
    local start3=Vector2.new(centerX+dir3.X*crosshairGap, centerY+dir3.Y*crosshairGap)
    local start4=Vector2.new(centerX+dir4.X*crosshairGap, centerY+dir4.Y*crosshairGap)
    
    topLine.From=start1
    topLine.To=Vector2.new(start1.X+dir1.X*crosshairLength, start1.Y+dir1.Y*crosshairLength)
    topLine.Color=color
    topLine.Visible=true
    
    bottomLine.From=start3
    bottomLine.To=Vector2.new(start3.X+dir3.X*crosshairLength, start3.Y+dir3.Y*crosshairLength)
    bottomLine.Color=color
    bottomLine.Visible=true
    
    leftLine.From=start2
    leftLine.To=Vector2.new(start2.X+dir2.X*crosshairLength, start2.Y+dir2.Y*crosshairLength)
    leftLine.Color=color
    leftLine.Visible=true
    
    rightLine.From=start4
    rightLine.To=Vector2.new(start4.X+dir4.X*crosshairLength, start4.Y+dir4.Y*crosshairLength)
    rightLine.Color=color
    rightLine.Visible=true
end

