local activeStates = {
    Aimbot = false,
    ["Auto Fire"] = false,
    ["Camera bug"] = false,
    ["Peek Helper"] = false,
    Menu = false
}

local function isKeyPressed(key)
    if type(key) == "string" then
        if key == "Mouse1" then
            return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
        elseif key == "Mouse2" then
            return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
        elseif key == "Mouse3" then
            return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton3)
        end
    end
    
    if key and type(key) == "userdata" then
        local success, result = pcall(function()
            return UserInputService:IsKeyDown(key)
        end)
        if success then
            return result
        end
    end
    
    return false
end

local function updateActiveBinds()
    for name, data in pairs(bindLabels) do
        data.keyLabel.Text = formatKeyName(data.getKey())
    end
    
    if aimbotEnabled then
        activeStates.Aimbot = isKeyPressed(aimbotKey)
    else
        activeStates.Aimbot = false
    end
    
    if autoFireEnabled and not ignoreAutoFireKey then
        activeStates["Auto Fire"] = isKeyPressed(autoFireKey)
    else
        activeStates["Auto Fire"] = false
    end
    
    activeStates["Camera bug"] = thirdPersonEnabled
    
    if peekHelperEnabled then
        activeStates["Peek Helper"] = isKeyPressed(peekHelperKey)
    else
        activeStates["Peek Helper"] = false
    end
    
    activeStates.Menu = menuVisible
    
    for name, isActive in pairs(activeStates) do
        if bindLabels[name] then
            bindLabels[name].frame.Visible = isActive
        end
    end
end

RunService.RenderStepped:Connect(updateActiveBinds)

