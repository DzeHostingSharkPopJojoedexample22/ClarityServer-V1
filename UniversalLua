local function speedChangerFunction()
    if not speedChangerEnabled then return end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local moveDirection = humanoid.MoveDirection
    if moveDirection.Magnitude > 0 then
        local rootPart = character:FindFirstChild("HumanoidRootPart")
        if rootPart then
            local velocity = rootPart.Velocity
            local horizontalVel = Vector3.new(velocity.X, 0, velocity.Z)
            if horizontalVel.Magnitude > 0 then
                local direction = horizontalVel.Unit
                rootPart.Velocity = Vector3.new(
                    direction.X * horizontalVel.Magnitude * SPEED_CHANGER_MULTIPLIER,
                    velocity.Y,
                    direction.Z * horizontalVel.Magnitude * SPEED_CHANGER_MULTIPLIER
                )
            end
        end
    end
end

RunService.Heartbeat:Connect(speedChangerFunction)

-- ПЛАВНЫЙ PRESTRAFE
local function preStrafeFunction()
    if not preStrafeEnabled then return end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    
    if not humanoid or not rootPart then return end
    
    -- Проверяем, находится ли персонаж в воздухе
    local isInAir = (humanoid:GetState() == Enum.HumanoidStateType.Freefall) or (humanoid:GetState() == Enum.HumanoidStateType.Jumping)
    local moveDirection = humanoid.MoveDirection
    
    if isInAir and moveDirection.Magnitude > 0 then
        -- Целевая скорость (медленнее)
        local targetVelocity = moveDirection * (preStrafeSpeed * 2.8)
        
        -- Текущая горизонтальная скорость
        local currentHorizontalVel = Vector3.new(rootPart.Velocity.X, 0, rootPart.Velocity.Z)
        
        -- Очень плавно меняем скорость (0.03 - очень медленно)
        local SMOOTH_FACTOR = 0.09
        local newHorizontalVel = currentHorizontalVel:Lerp(targetVelocity, SMOOTH_FACTOR)
        
        -- Применяем новую скорость
        rootPart.Velocity = Vector3.new(newHorizontalVel.X, rootPart.Velocity.Y, newHorizontalVel.Z)
    end
end

RunService.Heartbeat:Connect(preStrafeFunction)

