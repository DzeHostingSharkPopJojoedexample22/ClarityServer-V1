-- =====================================================
-- Spinbot переменные
-- =====================================================
spinbotEnabled = false
spinbotAngle = 0
spinbotDirection = 1
spinbotSpeed = 20
spinbotJitter = 0
spinbotPitch = 0
spinbotConnection = nil

function setupUndetectSpinbot()
    if spinbotConnection then
        spinbotConnection:Disconnect()
        spinbotConnection = nil
    end
    
    if not spinbotEnabled then return end
    
    local character = LocalPlayer.Character
    if not character then
        LocalPlayer.CharacterAdded:Connect(function()
            task.wait(0.5)
            if spinbotEnabled then
                setupUndetectSpinbot()
            end
        end)
        return
    end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    
    if not rootPart or not humanoid then return end
    
    spinbotConnection = RunService.Heartbeat:Connect(function()
        if not spinbotEnabled then
            if spinbotConnection then
                spinbotConnection:Disconnect()
                spinbotConnection = nil
            end
            return
        end
        
        local currentChar = LocalPlayer.Character
        if not currentChar then return end
        
        local currentRoot = currentChar:FindFirstChild("HumanoidRootPart")
        local currentHumanoid = currentChar:FindFirstChildOfClass("Humanoid")
        
        if not currentRoot or not currentHumanoid then return end
        
        if currentHumanoid.Health > 0 then
            spinbotJitter = spinbotJitter + 1
            
            if spinbotJitter % math.random(2, 4) == 0 then
                spinbotDirection = spinbotDirection * -1
                spinbotSpeed = math.random(50, 80)
            end
            
            spinbotAngle = spinbotAngle + spinbotDirection * spinbotSpeed
            if spinbotAngle > 180 then spinbotAngle = -180
            elseif spinbotAngle < -180 then spinbotAngle = 180 end
            
            local currentPos = currentRoot.Position
            currentRoot.CFrame = CFrame.new(currentPos) * CFrame.Angles(math.rad(spinbotPitch), math.rad(spinbotAngle), 0)
        end
    end)
end

function toggleUndetectSpinbot(state)
    spinbotEnabled = state
    
    if spinbotEnabled then
        spinbotAngle = 0
        spinbotDirection = 1
        spinbotJitter = 0
        setupUndetectSpinbot()
        print("✓ УЛЬТИМЕЙТИВНЫЙ Anti-Aim включен с наклоном "..spinbotPitch.."°")
    else
        if spinbotConnection then
            spinbotConnection:Disconnect()
            spinbotConnection = nil
        end
        print("✗ Anti-Aim выключен")
    end
end

LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    if spinbotEnabled then
        setupUndetectSpinbot()
    end
end)

