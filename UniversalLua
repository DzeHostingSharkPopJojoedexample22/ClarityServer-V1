-- AUTO FIRE
-- =====================================================
-- АВТОФАЕР (НЕ СТРЕЛЯЕТ В СТЕНУ)
-- =====================================================
local function autoFireLoop()
    if not autoFireEnabled then 
        isAutoFiring = false
        firstShotDone = false
        return 
    end
    
    if ignoreAutoFireKey then
        isAutoFiring = true
    end
    
    if isAutoFiring then
        local currentTime = os.clock() * 1000
        local delay = autoFireDelay
        
        if not firstShotDone and autoFireFirstShotDelay > 0 then
            delay = autoFireFirstShotDelay
        end
        
        if (currentTime - lastShotTime) < delay then
            return
        end
        
        local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        local target = nil
        local shortest = autoFireDistance
        
        -- Получаем позицию игрока
        local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not myRoot then return end
        
        for _, player in ipairs(Players:GetPlayers()) do
            if shouldTarget(player) then
                local part = getTargetPart(player)
                if part then
                    local pos, onScreen = Camera:WorldToScreenPoint(part.Position)
                    if onScreen then
                        local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                        
                        -- Проверка на стену (рейкаст)
                        local targetRoot = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                        if targetRoot then
                            local params = RaycastParams.new()
                            params.FilterType = Enum.RaycastFilterType.Blacklist
                            params.FilterDescendantsInstances = {LocalPlayer.Character}
                            
                            local direction = (targetRoot.Position - myRoot.Position).Unit
                            local ray = Workspace:Raycast(myRoot.Position, direction * (targetRoot.Position - myRoot.Position).Magnitude, params)
                            
                            -- Если луч НЕ уперся в стену (или уперся в цель)
                            if ray and ray.Instance:IsDescendantOf(player.Character) then
                                -- Видим цель
                                if dist < shortest then
                                    shortest = dist
                                    target = player
                                end
                            elseif not ray then
                                -- Нет препятствий
                                if dist < shortest then
                                    shortest = dist
                                    target = player
                                end
                            end
                            -- Если луч уперся в стену - пропускаем
                        end
                    end
                end
            end
        end
        
        if target then
            local part = getTargetPart(target)
            if part then
                local pos, onScreen = Camera:WorldToScreenPoint(part.Position)
                if onScreen and (Vector2.new(pos.X, pos.Y) - center).Magnitude < autoFireDistance then
                    if math.random(1, 100) <= hitChance then
                        playHitSound()
                        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
                        task.wait(0.03)
                        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
                        lastShotTime = currentTime
                        firstShotDone = true
                    end
                end
            end
        end
    end
end

UserInputService.InputBegan:Connect(function(input)
    if not ignoreAutoFireKey and checkKey(input, autoFireKey) and autoFireEnabled then
        isAutoFiring = true
        firstShotDone = false
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if not ignoreAutoFireKey and checkKey(input, autoFireKey) then
        isAutoFiring = false
        firstShotDone = false
    end
end)

