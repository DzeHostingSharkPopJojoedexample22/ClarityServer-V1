local function isOnSameTeam(player)
    if not player then return false end
    if LocalPlayer.Team and player.Team then return LocalPlayer.Team == player.Team end
    if LocalPlayer.TeamColor and player.TeamColor then return LocalPlayer.TeamColor == player.TeamColor end
    return false
end

local function getMultiPointPart(player)
    if not player or not player.Character then return nil end
    
    local parts = {"Head", "Head", "Torso", "UpperTorso", "Left Arm", "Right Arm", "Left Leg", "Right Leg"}
    local attempts = 0
    
    while attempts < 10 do
        local partName = parts[math.random(1, #parts)]
        local part = player.Character:FindFirstChild(partName)
        if part and part:IsA("BasePart") then return part end
        attempts = attempts + 1
    end
    
    return player.Character:FindFirstChild("Head")
end

local function getTargetPart(player)
    if not player or not player.Character then return nil end
    
    if multiPointEnabled and math.random(1, 100) <= multiPointChance then
        return getMultiPointPart(player)
    end
    
    if hitPart == "Head" then
        return player.Character:FindFirstChild("Head")
    elseif hitPart == "Body" then
        return player.Character:FindFirstChild("HumanoidRootPart") or player.Character:FindFirstChild("Torso")
    elseif hitPart == "Nearest" then
        local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        local closest, closestDist = nil, math.huge
        
        for _, name in ipairs({"Head", "HumanoidRootPart", "Torso"}) do
            local part = player.Character:FindFirstChild(name)
            if part then
                local pos, onScreen = Camera:WorldToScreenPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist < closestDist then
                        closestDist = dist
                        closest = part
                    end
                end
            end
        end
        return closest
    elseif hitPart == "Random" then
        local parts = {"Head", "HumanoidRootPart", "Torso", "UpperTorso", "LowerTorso"}
        return player.Character:FindFirstChild(parts[math.random(1, #parts)])
    end
    
    return player.Character:FindFirstChild("Head")
end

local function isPlayerVisible(player)
    if not player or not player.Character or not LocalPlayer.Character then return false end
    
    local origin = LocalPlayer.Character:FindFirstChild("Head") or LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    local target = getTargetPart(player)
    
    if not origin or not target then return false end
    
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {LocalPlayer.Character}
    
    local ray = Workspace:Raycast(origin.Position, (target.Position - origin.Position).Unit * 1000, params)
    return not ray or ray.Instance:IsDescendantOf(player.Character)
end

local function shouldTarget(player)
    if player == LocalPlayer then return false end
    local char = player.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return false end
    if teamCheck and isOnSameTeam(player) then return false end
    if visibleCheck and not isPlayerVisible(player) then return false end
    return true
end

local function getClosestTarget()
    local closest, shortest = nil, math.huge
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, player in ipairs(Players:GetPlayers()) do
        if shouldTarget(player) then
            local part = getTargetPart(player)
            if part then
                local pos, onScreen = Camera:WorldToScreenPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist < shortest and dist < fovRadius then
                        shortest = dist
                        closest = player
                    end
                end
            end
        end
    end
    return closest
end

local function aimbotFunction()
    if not aimbotEnabled or silentAimEnabled then return end
    if fovRadius == 0 then return end
    
    local target = getClosestTarget()
    if target then
        local part = getTargetPart(target)
        if part and math.random(1, 100) <= hitChance then
            playHitSound()
            local smooth = aimbotSmooth / 25
            if smooth > 1 then smooth = 1 end
            local targetCF = CFrame.new(Camera.CFrame.Position, part.Position)
            Camera.CFrame = Camera.CFrame:Lerp(targetCF, smooth)
        end
    end
end

local function checkKey(input, key)
    if not input then return false end
    return (key == "Mouse1" and input.UserInputType == Enum.UserInputType.MouseButton1) or
           (key == "Mouse2" and input.UserInputType == Enum.UserInputType.MouseButton2) or
           (input.KeyCode and input.KeyCode == key)
end

