    peekHelperCircle = circle
end

local function handlePeekHelper()
    if not peekHelperEnabled then
        if peekHelperCircle then
            peekHelperCircle:Destroy()
            peekHelperCircle = nil
        end
        peekHelperActive = false
        peekHelperReturning = false
        return
    end
    
    local character = LocalPlayer.Character
    if not character then return end
    
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    
    if peekHelperActive and not peekHelperReturning then
        if not peekHelperCircle then
            createPeekHelperCircle()
            if peekHelperCircle then
                peekHelperPosition = rootPart.Position
                peekHelperCircle.Position = peekHelperPosition + Vector3.new(0, 0.2, 0)
                
                local sound = peekHelperCircle:FindFirstChildOfClass("Sound")
                if sound then sound:Play() end
            end
        end
        
        if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) or 
           (autoFireEnabled and isAutoFiring) then
            peekHelperReturning = true
        end
    end
    
    if peekHelperReturning and peekHelperPosition and peekHelperCircle then
        local distance = (rootPart.Position - peekHelperPosition).Magnitude
        
        if distance > 1 then
            local direction = (peekHelperPosition - rootPart.Position).Unit
            rootPart.Velocity = direction * PEEK_HELPER_SPEED
        else
            rootPart.Velocity = Vector3.new(0, rootPart.Velocity.Y, 0)
            rootPart.Position = peekHelperPosition
            peekHelperReturning = false
        end
    end
end

