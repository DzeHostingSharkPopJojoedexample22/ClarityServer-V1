    end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "ChamsHighlight"
    highlight.Adornee = nil
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.FillTransparency = chamsTransparency
    highlight.OutlineTransparency = 0
    highlight.Enabled = false
    highlight.Parent = Workspace
    
    chamsHighlights[player] = highlight
end

local function updateChamsVisuals()
    if not (chamsVisible or chamsInvisible) then
        for player, highlight in pairs(chamsHighlights) do
            if highlight then
                highlight.Enabled = false
            end
        end
        return
    end
    
    for player, highlight in pairs(chamsHighlights) do
        if player and highlight then
            local character = player.Character
            if character then
                highlight.Adornee = character
                
                if teamCheckEsp and player.Team == LocalPlayer.Team then
                    highlight.Enabled = false
                    continue
                end
                
                local humanoid = character:FindFirstChild("Humanoid")
                if deadCheckEsp and humanoid and humanoid.Health <= 0 then
                    highlight.Enabled = false
                    continue
                end
                
                local rootPart = character:FindFirstChild("HumanoidRootPart")
                if rootPart then
                    local screenPos = Camera:WorldToViewportPoint(rootPart.Position)
                    local isVisible = screenPos.Z > 0
                    
                    if isVisible and chamsVisible then
                        highlight.FillColor = chamsVisibleColor
                        highlight.OutlineColor = chamsVisibleColor
                        highlight.Enabled = true
                    elseif not isVisible and chamsInvisible then
