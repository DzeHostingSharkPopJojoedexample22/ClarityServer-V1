-- САЙЛЕНТ
-- =====================================================
function getSilentAimTarget()
    local closest = nil
    local shortest = math.huge
    local center = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, player in ipairs(Players:GetPlayers()) do
        if shouldTarget(player) then
            local part = getTargetPart(player)
            if part then
                local pos, onScreen = Camera:WorldToScreenPoint(part.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if dist < shortest and dist < fovRadius then
                        shortest = dist
                        closest = player
                    end
                end
            end
        end
    end
    return closest
end

function doSilentAim()
    if not silentAimEnabled or not aimbotEnabled then return end
    if fovRadius == 0 then return end
    
    local target = getSilentAimTarget()
    if target then
        local part = getTargetPart(target)
        if part and math.random(1, 100) <= hitChance then
            
            local targetRoot = target.Character and target.Character:FindFirstChild("HumanoidRootPart")
            local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            
            -- Сохраняем старую камеру
            local oldCF = Camera.CFrame
            
            if targetRoot and myRoot then
                -- Предикт для летающих
                local targetVel = targetRoot.Velocity
                local dist = (targetRoot.Position - myRoot.Position).Magnitude
                local BULLET_SPEED = 2000
                local flightTime = dist / BULLET_SPEED
                local futurePos = part.Position + (targetVel * flightTime * 0.9)
                
                -- Наводим камеру на цель (с предиктом)
                Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, futurePos)
            else
                -- Наводим камеру на цель (без предикта)
                Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, part.Position)
            end
            
            -- ВЫСТРЕЛ через VirtualInputManager
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
            task.wait(0.001)
            VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
            
            -- Возвращаем камеру
            Camera.CFrame = oldCF
            
            playHitSound()
        end
    end
end

-- Перехватываем ЛКМ
UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and silentAimEnabled then
        doSilentAim()
        return
    end
end)

