local function updateEspVisuals()
    local currentCamera = workspace.CurrentCamera
    local cameraCFrame = currentCamera.CFrame
    local viewportSize = currentCamera.ViewportSize
    
    if not espEnabled then
        for player, items in pairs(espItems) do
            if items then
                items.box.Visible = false
                items.name.Visible = false
                items.health.Visible = false
                items.tool.Visible = false
                items.distance.Visible = false
                items.healthBarOutline.Visible = false
                items.healthBarFill.Visible = false
                if items.skeleton then
                    for _, line in ipairs(items.skeleton) do
                        line.Visible = false
                    end
                end
            end
        end
        return
    end
    
    for player, items in pairs(espItems) do
        if not player then continue end
        
        local character = player.Character
        if not character then 
            if items then
                items.box.Visible = false
                items.name.Visible = false
                items.health.Visible = false
                items.tool.Visible = false
                items.distance.Visible = false
                items.healthBarOutline.Visible = false
                items.healthBarFill.Visible = false
                if items.skeleton then
                    for _, line in ipairs(items.skeleton) do
                        line.Visible = false
                    end
                end
            end
            continue 
        end
        
        local humanoid = character:FindFirstChild("Humanoid")
        local head = character:FindFirstChild("Head")
        local rootPart = character:FindFirstChild("HumanoidRootPart") or character:FindFirstChild("Torso") or character:FindFirstChild("UpperTorso")
        
        if not humanoid or not head or not rootPart or humanoid.Health <= 0 then 
            if items then
                items.box.Visible = false
                items.name.Visible = false
                items.health.Visible = false
                items.tool.Visible = false
                items.distance.Visible = false
                items.healthBarOutline.Visible = false
                items.healthBarFill.Visible = false
                if items.skeleton then
                    for _, line in ipairs(items.skeleton) do
                        line.Visible = false
                    end
                end
            end
            continue 
        end
        
        if (teamCheckEsp and player.Team == LocalPlayer.Team) or (deadCheckEsp and humanoid.Health <= 0) then
            if items then
                items.box.Visible = false
                items.name.Visible = false
                items.health.Visible = false
                items.tool.Visible = false
                items.distance.Visible = false
                items.healthBarOutline.Visible = false
                items.healthBarFill.Visible = false
                if items.skeleton then
                    for _, line in ipairs(items.skeleton) do
                        line.Visible = false
                    end
                end
            end
            continue
        end
        
        local headPosition = head.Position
        local rootPosition = rootPart.Position
        
        local headVec = currentCamera:WorldToViewportPoint(headPosition)
        local rootVec = currentCamera:WorldToViewportPoint(rootPosition - Vector3.new(0, 3, 0))
        
        local headPos = Vector2.new(headVec.X, headVec.Y)
        local headOnScreen = headVec.Z > 0
        local feetPos = Vector2.new(rootVec.X, rootVec.Y)
        
        if not headOnScreen then
            if items then
                items.box.Visible = false
                items.name.Visible = false
                items.health.Visible = false
                items.tool.Visible = false
                items.distance.Visible = false
                items.healthBarOutline.Visible = false
                items.healthBarFill.Visible = false
                if items.skeleton then
                    for _, line in ipairs(items.skeleton) do
                        line.Visible = false
                    end
                end
            end
            continue
        end
        
        local boxTop = headPos.Y
        local boxBottom = feetPos.Y
        local boxHeight = math.abs(boxTop - boxBottom)
        local boxWidth = boxHeight * 0.5
        local boxX = headPos.X - boxWidth/2
        local boxY = math.min(boxTop, boxBottom)
        
        if espEnabled and boxEsp then
            items.box.Visible = true
            items.box.Size = Vector2.new(boxWidth, boxHeight)
            items.box.Position = Vector2.new(boxX, boxY)
            items.box.Color = boxColor
        else
            items.box.Visible = false
        end
        
        if espEnabled and nameEsp then
            items.name.Visible = true
            items.name.Position = Vector2.new(headPos.X, boxY - 20)
            items.name.Text = player.Name
            items.name.Color = nameColor
        else
            items.name.Visible = false
        end
        
        if espEnabled and healthEsp then
            items.health.Visible = true
            items.health.Position = Vector2.new(headPos.X, boxY + boxHeight + 5)
            items.health.Text = "HP: " .. math.floor(humanoid.Health)
            items.health.Color = healthColor
        else
            items.health.Visible = false
        end
        
        if espEnabled and toolEsp then
            local currentTool = character:FindFirstChildOfClass("Tool") or (player:FindFirstChild("Backpack") and player.Backpack:FindFirstChildOfClass("Tool"))
            items.tool.Visible = true
            items.tool.Position = Vector2.new(headPos.X, boxY + boxHeight + 25)
            items.tool.Text = "Tool: " .. (currentTool and currentTool.Name or "None")
            items.tool.Color = toolColor
        else
            items.tool.Visible = false
        end
        
        if espEnabled and distanceEsp and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local distance = (rootPosition - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            items.distance.Visible = true
            items.distance.Position = Vector2.new(headPos.X, boxY + boxHeight + 45)
            items.distance.Text = math.floor(distance) .. " studs"
            items.distance.Color = distanceColor
        else
            items.distance.Visible = false
        end
        
        if espEnabled and healthBar then
            local healthPercentage = humanoid.Health / humanoid.MaxHealth
            local barWidth = 6
            local barHeight = boxHeight
            local barX = boxX - 10
            local barY = boxY
            
            items.healthBarOutline.Visible = true
            items.healthBarOutline.Size = Vector2.new(barWidth, barHeight)
            items.healthBarOutline.Position = Vector2.new(barX, barY)
            
            items.healthBarFill.Visible = true
            local fillHeight = barHeight * healthPercentage
            items.healthBarFill.Size = Vector2.new(barWidth - 2, fillHeight)
            items.healthBarFill.Position = Vector2.new(barX + 1, barY + (barHeight - fillHeight))
            
            if healthPercentage > 0.7 then
                items.healthBarFill.Color = Color3.fromRGB(0, 255, 0)
            elseif healthPercentage > 0.3 then
                items.healthBarFill.Color = Color3.fromRGB(255, 255, 0)
            else
                items.healthBarFill.Color = Color3.fromRGB(255, 0, 0)
            end
        else
            items.healthBarOutline.Visible = false
            items.healthBarFill.Visible = false
        end
        
        -- =====================================================
        -- КРАСИВЫЕ СКЕЛЕТОНЫ
        -- =====================================================
         if espEnabled and skeletonEsp then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if not humanoid then
                if items.skeleton then
                    for _, line in ipairs(items.skeleton) do
                        line.Visible = false
                    end
                end
                continue
            end
            
            local joints
            if humanoid.RigType == Enum.HumanoidRigType.R15 then
                joints = {
                    {"Head", "UpperTorso"},
                    {"UpperTorso", "LowerTorso"},
                    {"UpperTorso", "LeftUpperArm"},
                    {"LeftUpperArm", "LeftLowerArm"},
                    {"LeftLowerArm", "LeftHand"},
                    {"UpperTorso", "RightUpperArm"},
                    {"RightUpperArm", "RightLowerArm"},
                    {"RightLowerArm", "RightHand"},
                    {"LowerTorso", "LeftUpperLeg"},
                    {"LeftUpperLeg", "LeftLowerLeg"},
                    {"LeftLowerLeg", "LeftFoot"},
                    {"LowerTorso", "RightUpperLeg"},
                    {"RightUpperLeg", "RightLowerLeg"},
                    {"RightLowerLeg", "RightFoot"}
                }
            else
                -- R6
                joints = {
                    {"Head", "Torso"},
                    {"Torso", "Left Arm"},
                    {"Left Arm", "Left Arm"},
                    {"Torso", "Right Arm"},
                    {"Right Arm", "Right Arm"},
                    {"Torso", "Left Leg"},
                    {"Left Leg", "Left Leg"},
                    {"Torso", "Right Leg"},
                    {"Right Leg", "Right Leg"}
                }
            end
            
            -- Создаем линии если их нет или недостаточно
            if not items.skeleton then
                items.skeleton = {}
            end
            
            -- Добавляем недостающие линии
            for i = #items.skeleton + 1, #joints do
                local line = Drawing.new("Line")
                line.Thickness = 1.5
                line.Color = skeletonColor
                line.Transparency = 1
                line.Visible = false
                table.insert(items.skeleton, line)
            end
            
            -- Скрываем лишние линии
            for i = #joints + 1, #items.skeleton do
                if items.skeleton[i] then
                    items.skeleton[i].Visible = false
                end
            end
            
            -- Рисуем скелет
            for i, pair in ipairs(joints) do
                local line = items.skeleton[i]
                if not line then continue end
                
                local part1 = character:FindFirstChild(pair[1])
                local part2 = character:FindFirstChild(pair[2])
                
                if part1 and part2 then
                    local pos1, vis1 = currentCamera:WorldToViewportPoint(part1.Position)
                    local pos2, vis2 = currentCamera:WorldToViewportPoint(part2.Position)
                    
                    if vis1 and vis2 then
                        line.From = Vector2.new(pos1.X, pos1.Y)
                        line.To = Vector2.new(pos2.X, pos2.Y)
                        line.Visible = true
                        line.Color = skeletonColor
                    else
                        line.Visible = false
                    end
                else
                    line.Visible = false
                end
            end
        else
            if items.skeleton then
                for _, line in ipairs(items.skeleton) do
                    line.Visible = false
                end
            end
        end
    end
end

local function clearEspForPlayer(player)
    local items = espItems[player]
    if items then
        pcall(function()
            items.box:Remove()
            items.name:Remove()
            items.health:Remove()
            items.tool:Remove()
            items.distance:Remove()
            items.healthBarOutline:Remove()
            items.healthBarFill:Remove()
            if items.skeleton then
                for _, line in ipairs(items.skeleton) do
                    line:Remove()
                end
            end
        end)
        espItems[player] = nil
    end
end

